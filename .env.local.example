# 복사해서 .env.local 로 사용. .env.local 은 커밋 금지(.gitignore 보호).
# 로컬 스크립트 실행: node --env-file=.env.local scripts/collect.mjs

# ── 클라이언트(Next.js, 브라우저 노출) : anon key + RLS만 ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── 서버 전용 (scripts/collect.mjs, attachments.mjs, ai.mjs) ──
# 절대 NEXT_PUBLIC_ 접두어 금지. GitHub Actions 에서는 Secrets 로 주입.
NARA_API_BASE=https://apis.data.go.kr/1230000/ad/BidPublicInfoService
NARA_SERVICE_KEY=            # 공공데이터포털 서비스키(디코딩 키). 특수문자 있으면 Encoding 키 사용
NARA_BID_TYPES=servc        # servc(용역)|cnstwk(공사)|thng(물품), 콤마 구분

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=       # service_role 키 (RLS 우회, 서버 전용)
OPENROUTER_API_KEY=
APP_MASTER_KEY=             # app_settings.value_enc AES-256-GCM 마스터키
HMAC_KEY=                   # email/phone 해시용 HMAC-SHA256 키

# ── 로컬/호스팅 파일 저장 위치 ──
# 미설정 시 프로젝트 storage/ 사용(로컬 개발). 호스팅(Render 등)에서는 영구 디스크
# 마운트 경로를 지정한다. 예) Render: /var/data
# STORAGE_DIR=
